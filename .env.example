# ========== LOCAL DEVELOPMENT ==========
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite local, PostgreSQL in production via DATABASE_URL on Render)
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ========== PRODUCTION (RENDER) ==========
# Uncomment and update for Render deployment:
# SECRET_KEY=your-very-secure-secret-key-here
# DEBUG=False
# ALLOWED_HOSTS=sghi-backend.onrender.com
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=sghi_db
# DB_USER=sghi_user
# DB_PASSWORD=your-db-password-from-render
# DB_HOST=dpg-xxxxx.postgres.render.com
# DB_PORT=5432

# Frontend URLs
FRONTEND_BASE_URL=http://localhost:5173
SITE_URL=http://127.0.0.1:8000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080

# Redis (Optional)
REDIS_URL=redis://127.0.0.1:6379/1

# JWT
JWT_ACCESS_LIFETIME_MINUTES=30
JWT_REFRESH_LIFETIME_DAYS=7

# Email (Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
# Gmail : utilisez un "Mot de passe d'application" (pas le mot de passe du compte)
# https://myaccount.google.com/apppasswords
DEFAULT_FROM_EMAIL=SGHL CHU Brazzaville <votre.email@gmail.com>
# Boîte mail recevant les codes MFA du personnel (admin, médecins, etc.)
MFA_HOSPITAL_EMAIL=

# Afficher le code MFA à l'écran (en plus de l'email) — saisie plus rapide
MFA_SHOW_CODE_ON_SCREEN=True

# Other
PATIENT_CARD_TOKEN_DAYS=365

